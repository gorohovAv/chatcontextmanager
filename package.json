{
  "name": "chatcontextmanager",
  "displayName": "Prompt scoop",
  "description": "Easily compile a prompt for any AI chat",
  "version": "1.1.0",
  "publisher": "Eggplant11",
  "repository": {
    "type": "git",
    "url": "https://github.com/gorohovAv/chatcontextmanager.git"
  },
  "icon": "resources/icon.png", 
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
    "keywords": [
    "prompt",
    "ai",
    "chat",
    "llm",
    "context"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "enabledApiProposals": [
    "terminalDataWriteEvent"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prompt-builder",
          "title": "Prompt Builder",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "prompt-builder": [
        {
          "type": "webview",
          "id": "promptBuilderView",
          "name": "Prompt Builder"
        },
        {
          "type": "webview",
          "id": "settingsView",
          "name": "Settings view"
        },
        {
          "type": "webview",
          "id": "logInterceptorView",
          "name": "Log Interceptor"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}