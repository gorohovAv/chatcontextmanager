{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "watch",
			"problemMatcher": "$esbuild-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "npm",
			"script": "build",
			"problemMatcher": "$esbuild-build"
		},
		{
			"label": "esbuild-watch",
			"type": "process",
			"command": "node",
			"args": ["esbuild.js", "--watch"],
			"isBackground": true,
			"problemMatcher": [
				{
					"owner": "esbuild",
					"fileLocation": ["relative", "${workspaceFolder}"],
					"pattern": {
						"regexp": "^([^\\s].*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
						"file": 1,
						"line": 2,
						"column": 3,
						"severity": 4,
						"message": 5
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": "^\\[watch\\] build started",
						"endsPattern": "^\\[watch\\] build finished"
					}
				}
			]
		},
		{
			"label": "esbuild-build",
			"type": "process",
			"command": "node",
			"args": ["esbuild.js"],
			"problemMatcher": [
				{
					"owner": "esbuild",
					"fileLocation": ["relative", "${workspaceFolder}"],
					"pattern": {
						"regexp": "^([^\\s].*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
						"file": 1,
						"line": 2,
						"column": 3,
						"severity": 4,
						"message": 5
					}
				}
			]
		}
	]
}